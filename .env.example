# Supabase Configuration
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Database Connection
# Get from: Supabase Dashboard → Project Settings → Database → Connection String
# Use "Connection Pooling" string for better performance
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.ywgjnkjtwaxcspahlkik:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Development Debug Token (for local testing without real JWT)
# Use this token in Authorization header during development: Bearer super-secret-debug-token-local-dev
DEBUG_TOKEN=super-secret-debug-token-local-dev

# Environment
ENVIRONMENT=development
